# Slack API credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Public URL (for Slack events, etc.)
BASE_URL=http://localhost:8080

# Database (PostgreSQL)
DATABASE_URL=postgres://indigestion:indigestion@localhost:5432/indigestion

# REST API (optional — leave empty to disable auth)
API_USERNAME=admin
API_PASSWORD=your-api-password

# Lockdown (optional — comma-separated Slack user IDs allowed to run commands)
LOCKDOWN_USERS=U07VA44DNBA,U09Q8MLTE58

# Hack Club CDN (optional — upload file_input attachments to Hack Club CDN)
HACK_CLUB_CDN_KEY=sk_cdn_your_key_here

# Cloudflare Tunnel (optional)
TUNNEL_TOKEN=your-cloudflare-tunnel-token
